# Docker Environment Configuration
# Copy this file to .env.docker and update with your production values
# Then run: docker-compose up -d

# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=production
PORT=5000
APP_URL=https://api.aqherbal.com

# Database (Docker service names)
MONGODB_URI=mongodb://mongo:27017/aqherbal
DB_URL=mongodb://mongo:27017/aqherbal
DB_NAME=aqherbal

# JWT Authentication (MUST CHANGE IN PRODUCTION!)
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_64_CHARS_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_SECURE_RANDOM_STRING_MIN_64_CHARS_PRODUCTION
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# URLs
FRONTEND_URL=https://aqherbal.com

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-production-email@aqherbal.com
EMAIL_PASSWORD=your-production-app-password
EMAIL_FROM=AQ Herbal <noreply@aqherbal.com>

# Legacy variables
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-production-email@aqherbal.com
SMTP_PASS=your-production-app-password

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME=your-production-cloud-name
CLOUDINARY_API_KEY=your-production-api-key
CLOUDINARY_API_SECRET=your-production-api-secret
CLOUDINARY_NAME=your-production-cloud-name

# ============================================
# PAYMENT GATEWAY (PRODUCTION)
# ============================================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-production-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-production-webhook-secret

STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

PAYMENT_METHODS=card,netbanking,upi,wallet
RAZORPAY_METHODS=card,netbanking,upi
PAYMENT_CURRENCY=INR
PAYMENT_MAX_RETRIES=3
PAYMENT_RETRY_WINDOW=24

# ============================================
# REDIS (Docker service)
# ============================================
REDIS_DISABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://redis:6379
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=10000
REDIS_KEY_PREFIX=aqherbal:

# ============================================
# RATE LIMITING (Production)
# ============================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100
SUSPICIOUS_RATE_LIMIT_MAX=10
RATE_LIMIT_SENSITIVE_WINDOW=5m
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REVIEW_MAX=10
RATE_LIMIT_COUPON_MAX=20
RATE_LIMIT_CONTACT_MAX=5
RATE_LIMIT_WEBHOOK_MAX=100

# ============================================
# BUSINESS CONFIGURATION
# ============================================
TAX_RATE=0.1
GST_RATE=0.18
FREE_SHIPPING_THRESHOLD=500
SHIPPING_COST=0
EXPRESS_SHIPPING_COST=100
LOW_STOCK_THRESHOLD=10
OUT_OF_STOCK_THRESHOLD=0
REORDER_QUANTITY=50
ORDER_CANCELLATION_WINDOW=24
ORDER_RETURN_WINDOW=7
AUTO_CANCEL_PENDING_HOURS=48
VERIFIED_REVIEWS_ONLY=true
REVIEW_MODERATION=true
MAX_COUPON_DISCOUNT=50
MIN_COUPON_ORDER_VALUE=100

# ============================================
# ADMIN
# ============================================
ADMIN_EMAIL=admin@aqherbal.com
ADMIN_URL=https://admin.aqherbal.com

# ============================================
# COMPANY INFO
# ============================================
COMPANY_NAME=AQ Herbal
COMPANY_ADDRESS=Mumbai, Maharashtra, India
COMPANY_GSTIN=YOUR_GSTIN_NUMBER
SUPPORT_EMAIL=support@aqherbal.com
SUPPORT_PHONE=+91-1234567890

# ============================================
# SHIPMENT TRACKING
# ============================================
ENABLE_SHIPMENT_TRACKING_JOB=true
SHIPMENT_TRACKING_CRON=0 */4 * * *
TZ=Asia/Kolkata
INDIA_POST_API_URL=https://www.indiapost.gov.in/_layouts/15/dop.portal.tracking/trackconsignment.aspx
INDIA_POST_TIMEOUT=10000
USE_INDIA_POST_AGGREGATOR=false
TRACKING_AGGREGATOR_URL=
TRACKING_AGGREGATOR_API_KEY=
