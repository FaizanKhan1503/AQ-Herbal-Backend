# Test Environment Variables
NODE_ENV=test

# Database
MONGODB_URI=mongodb://localhost:27017/aqherbal_test
MONGODB_TEST_URI=mongodb://localhost:27017/aqherbal_test
DB_NAME=aqherbal_test

# JWT
JWT_SECRET=test_jwt_secret_key_for_testing_purposes_only_1234567890
JWT_REFRESH_SECRET=test_refresh_secret_key_for_testing_purposes_only_12345
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@aqherbal.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Redis
REDIS_DISABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_KEY_PREFIX=aqherbal_test:

# URLs
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Company Info
COMPANY_NAME=AQ Herbal
COMPANY_ADDRESS=Address
COMPANY_GSTIN=GSTIN

# Support
ADMIN_EMAIL=admin@test.com
SUPPORT_EMAIL=support@test.com
SUPPORT_PHONE=+911234567890

# Business Config
TAX_RATE=0.05
GST_RATE=0.18
FREE_SHIPPING_THRESHOLD=500
LOW_STOCK_THRESHOLD=10

# Review Config
VERIFIED_REVIEWS_ONLY=false
REVIEW_MODERATION=true

# Feature Flags
ENABLE_SHIPMENT_TRACKING_JOB=false

# Security
IP_BLACKLIST=
