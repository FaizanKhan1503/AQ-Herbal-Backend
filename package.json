  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:api-report": "node scripts/runApiTestReport.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "validate": "npm run lint && npm run test",
    "validate:lint-only": "npm run lint",
    "build": "npm run validate:lint-only && npm run bundle",
    "bundle": "node scripts/bundle.js",
    "prebuild": "npm run clean",
    "clean": "node scripts/clean.js",
    "check": "node scripts/health-check.js",
    "seed:coupons": "node scripts/seedCoupons.js",
    "test:coupons": "node scripts/testCoupons.js",
    "test:tracking": "node scripts/testShipmentTracking.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.4",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.5",
    "npm": "^11.4.2",
    "pg": "^8.16.3",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "stripe": "^18.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.7.3",
    "typeorm": "^0.3.25",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "jest": "^30.0.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3"
  }
}
