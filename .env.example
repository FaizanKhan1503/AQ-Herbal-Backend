# Environment Configuration for aqherbal_backend
# Copy this file to .env and update with your actual values

# ============================================
# CORE CONFIGURATION (REQUIRED)
# ============================================
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/aqherbal
DB_URL=mongodb://localhost:27017/aqherbal
DB_NAME=aqherbal

# JWT Authentication (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_min_32_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (required for email links)
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# ============================================
# EMAIL CONFIGURATION (REQUIRED FOR PRODUCTION)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=AQ Herbal <noreply@aqherbal.com>

# Legacy SMTP variables (for backward compatibility)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# CLOUDINARY (REQUIRED FOR IMAGE UPLOADS)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Legacy Cloudinary variables (for backward compatibility)
CLOUDINARY_NAME=your-cloud-name

# ============================================
# PAYMENT GATEWAY (REQUIRED FOR PRODUCTION)
# ============================================
# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# Payment Configuration
PAYMENT_METHODS=card,netbanking,upi,wallet
RAZORPAY_METHODS=card,netbanking,upi
PAYMENT_CURRENCY=INR
PAYMENT_MAX_RETRIES=3
PAYMENT_RETRY_WINDOW=24

# ============================================
# REDIS CACHE (OPTIONAL)
# ============================================
REDIS_DISABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=10000
REDIS_KEY_PREFIX=aqherbal:

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=200
SUSPICIOUS_RATE_LIMIT_MAX=20
RATE_LIMIT_SENSITIVE_WINDOW=5m
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REVIEW_MAX=15
RATE_LIMIT_COUPON_MAX=30
RATE_LIMIT_CONTACT_MAX=10
RATE_LIMIT_WEBHOOK_MAX=50

# ============================================
# INPUT VALIDATION & SPAM PROTECTION
# ============================================
INPUT_MAX_DEPTH=8
INPUT_MAX_STRING_LENGTH=5000
SPAM_MAX_LINKS=5
SPAM_MAX_KEYWORD_HITS=3
SPAM_MAX_PAYLOAD_BYTES=51200
SPAM_MAX_REPEAT_RUN=12

# ============================================
# BUSINESS CONFIGURATION
# ============================================
# Tax
TAX_RATE=0.1
GST_RATE=0.18

# Shipping
FREE_SHIPPING_THRESHOLD=500
SHIPPING_COST=0
EXPRESS_SHIPPING_COST=100

# Inventory
LOW_STOCK_THRESHOLD=10
OUT_OF_STOCK_THRESHOLD=0
REORDER_QUANTITY=50

# Orders
ORDER_CANCELLATION_WINDOW=24
ORDER_RETURN_WINDOW=7
AUTO_CANCEL_PENDING_HOURS=48

# Reviews
VERIFIED_REVIEWS_ONLY=false
REVIEW_MODERATION=true

# Coupons
MAX_COUPON_DISCOUNT=50
MIN_COUPON_ORDER_VALUE=100

# ============================================
# ADMIN CONFIGURATION
# ============================================
ADMIN_EMAIL=admin@aqherbal.com
ADMIN_URL=http://localhost:3001

# ============================================
# COMPANY INFORMATION
# ============================================
COMPANY_NAME=AQ Herbal
COMPANY_ADDRESS=Mumbai, Maharashtra, India
COMPANY_GSTIN=
SUPPORT_EMAIL=support@aqherbal.com
SUPPORT_PHONE=+91-1234567890

# ============================================
# SECURITY
# ============================================
BLACKLISTED_IPS=

# ============================================
# SHIPMENT TRACKING (OPTIONAL)
# ============================================
ENABLE_SHIPMENT_TRACKING_JOB=false
SHIPMENT_TRACKING_CRON=0 */4 * * *
TZ=Asia/Kolkata

# India Post Tracking
INDIA_POST_API_URL=https://www.indiapost.gov.in/_layouts/15/dop.portal.tracking/trackconsignment.aspx
INDIA_POST_TIMEOUT=10000
USE_INDIA_POST_AGGREGATOR=false
TRACKING_AGGREGATOR_URL=
TRACKING_AGGREGATOR_API_KEY=
